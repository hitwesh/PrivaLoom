# PrivaLoom runtime persistence configuration
# Copy this file to .env and adjust paths as needed.

# Auth
AUTH_ENABLED=true
AUTH_DB_PATH=data/auth.db
AUTH_BOOTSTRAP_ADMIN=admin
AUTH_BOOTSTRAP_PASSWORD=admin123
# Optional: JSON list of users to seed on startup
# AUTH_SEED_FILE=data/users_seed.json

# Aggregation and security persistence
AGGREGATION_STATE_PATH=data/aggregation_state.json
PRIVACY_STATE_PATH=data/privacy_state.json
REPUTATION_STATE_PATH=data/reputation_state.json
SECURITY_EVENTS_PATH=data/security_events.jsonl

# Model persistence
MODEL_PERSIST_ENABLED=true
MODEL_STATE_PATH=data/model_state.pt

# Existing server options
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
UPDATE_THRESHOLD=20
AGGREGATION_METHOD=trimmed_mean
BYZANTINE_TOLERANCE=0.2
OUTLIER_DETECTION_ENABLED=true
REPUTATION_ENABLED=true
VALIDATION_ENABLED=true
SIMULATION_MODE=false
SIMULATION_LOGGING_VERBOSE=false
